// STREAMING_CHUNK: Defining User, Role and OTP Models...
enum Role {
CUSTOMER
ADMIN
}

model User {
id              String   @id @default(uuid())
email           String   @unique
password        String
firstName       String?
lastName        String?
phone           String?
role            Role     @default(CUSTOMER)
avatarUrl       String?
isEmailVerified Boolean  @default(false)

addresses       Address[]
orders          Order[]
reviews         Review[]
cart            Cart?
otpVerification OTPVerification?

createdAt       DateTime @default(now())
updatedAt       DateTime @updatedAt

@@index([email])
}

// STREAMING_CHUNK: Defining OTP Verification logic...
model OTPVerification {
id        String   @id @default(uuid())
userId    String   @unique
user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
otp       String
expiresAt DateTime
attempts  Int      @default(0)
isVerified Boolean @default(false)

createdAt DateTime @default(now())
updatedAt DateTime @updatedAt
}

// STREAMING_CHUNK: Defining User Addresses...
enum AddressType {
BILLING
SHIPPING
}

model Address {
id        String      @id @default(uuid())
userId    String
user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
type      AddressType
company   String?
street    String
city      String
state     String
zipCode   String
isDefault Boolean     @default(false)

orders    Order[]

createdAt DateTime    @default(now())
updatedAt DateTime    @updatedAt

@@index([userId])
}

// STREAMING_CHUNK: Catalog section - Services and Categories...
// ==========================================
// Catalog (Services, Categories & Products)
// ==========================================

model Service {
id          String     @id @default(uuid())
name        String     @unique
slug        String     @unique
description String?    @db.Text
icon        String?    // Icon URL or class name

categories  Category[] // Direct categories under this service
stepConfigurations ProductStepConfiguration[]

createdAt   DateTime   @default(now())
updatedAt   DateTime   @updatedAt

@@index([slug])
}

model Category {
id          String   @id @default(uuid())
serviceId   String
service     Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

name        String
slug        String   @unique
description String?

subcategories Subcategory[]
products      Product[]

// Relation to dynamic product attributes
attributes    ProductAttribute[]
stepConfigurations ProductStepConfiguration[]

createdAt   DateTime @default(now())
updatedAt   DateTime @updatedAt

@@index([serviceId])
@@index([slug])
}

// STREAMING_CHUNK: Defining Subcategories and Products...
model Subcategory {
id          String   @id @default(uuid())
categoryId  String
category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

name        String
slug        String   @unique
description String?

products    Product[]

createdAt   DateTime @default(now())
updatedAt   DateTime @updatedAt

@@index([categoryId])
@@index([slug])
}

model Product {
id            String       @id @default(uuid())
categoryId    String?
category      Category?    @relation(fields: [categoryId], references: [id])
subcategoryId String?
subcategory   Subcategory? @relation(fields: [subcategoryId], references: [id])
name          String
slug          String       @unique
description   String       @db.Text
basePrice     Decimal      @db.Decimal(10, 2)
images        String[]     // Array of image URLs
isFeatured    Boolean      @default(false)

// Stores specific attribute availability for THIS product (e.g., this exact mug has only "Black" & "White")
// Note: Actual User selections (like uploading an image) go into CartItem/OrderItem's customizationDetails
attributes    Json?

pricingTiers  PricingTier[]
reviews       Review[]
cartItems     CartItem[]
orderItems    OrderItem[]

createdAt     DateTime @default(now())
updatedAt     DateTime @updatedAt

@@index([categoryId])
}

// STREAMING_CHUNK: Defining Pricing logic...
// "Buy more, Save more" logic
model PricingTier {
id          String  @id @default(uuid())
productId   String
product     Product @relation(fields: [productId], references: [id], onDelete: Cascade)
minQuantity Int
maxQuantity Int?    // Null means unlimited
unitPrice   Decimal @db.Decimal(10, 2)

@@index([productId])
}

// ==========================================
// Pricing Rules (Global Platform Fees)
// ==========================================

enum PricingRuleType {
FIXED
PERCENTAGE
}

model PricingRule {
id          String          @id @default(uuid())
name        String          @unique
type        PricingRuleType @default(FIXED)
value       Decimal         @db.Decimal(10, 2)
description String?         @db.Text

createdAt   DateTime @default(now())
updatedAt   DateTime @updatedAt
}

// STREAMING_CHUNK: Dynamic Form Builder models with updates...
// ==========================================
// Dynamic Product Attributes (UPDATED)
// ==========================================

enum AttributeInputType {
CHECKBOX
RADIO
PILLS
RICH_PILLS
COLOR_SWATCHES
DROPDOWN
FILE_UPLOAD    // NEW: For logos/artwork
TEXT_INPUT     // NEW: For names/titles
TEXT_AREA      // NEW: For special instructions
}

model ProductAttribute {
id          String             @id @default(uuid())
name        String             // e.g., "Upload Artwork"
type        AttributeInputType

// NEW: Added for Form Builder Logic
stepOrder   Int                @default(0)

isRequired  Boolean            @default(false)

categoryId  String
category    Category           @relation(fields: [categoryId], references: [id], onDelete: Cascade)

options     AttributeOption[]

createdAt   DateTime @default(now())
updatedAt   DateTime @updatedAt

@@index([categoryId])
}

model AttributeOption {
id          String           @id @default(uuid())
attributeId String
attribute   ProductAttribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)

value       String           // Main text (e.g., "Matte Black", "12 oz")
subtext     String?          // For rich pills (e.g., "Wine & Coffee Tumbler")
colorHex    String?          // For color swatches (e.g., "#000000")

createdAt   DateTime @default(now())
updatedAt   DateTime @updatedAt

@@index([attributeId])
}

// ==========================================
// Product Customization Steps (Form Builder)
// ==========================================

model ProductStepConfiguration {
id          String   @id @default(uuid())
serviceId   String
service     Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
categoryId  String
category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

steps       ProductStep[]

createdAt   DateTime @default(now())
updatedAt   DateTime @updatedAt

@@unique([serviceId, categoryId])
@@index([serviceId])
@@index([categoryId])
}

model ProductStep {
id              String   @id @default(uuid())
configurationId String
configuration   ProductStepConfiguration @relation(fields: [configurationId], references: [id], onDelete: Cascade)

stepTitle       String
inputType       String   // FILE_UPLOAD, RADIO, CHECKBOX, DROPDOWN, PILLS, COLOR_SWATCHES, TEXT_INPUT, TEXT_AREA
isRequired      Boolean  @default(true)
stepOrder       Int      @default(0)

options         ProductStepOption[]

createdAt       DateTime @default(now())
updatedAt       DateTime @updatedAt

@@index([configurationId])
}

model ProductStepOption {
id              String   @id @default(uuid())
stepId          String
step            ProductStep @relation(fields: [stepId], references: [id], onDelete: Cascade)

optionValue     String
subtext         String?
colorHex        String?
optionOrder     Int      @default(0)

createdAt       DateTime @default(now())
updatedAt       DateTime @updatedAt

@@index([stepId])
}

// STREAMING_CHUNK: E-commerce Core logic (Cart & Orders)...
// ==========================================
// E-commerce Core (Cart & Orders)
// ==========================================

model Cart {
id        String     @id @default(uuid())
userId    String     @unique
user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
items     CartItem[]

updatedAt DateTime @updatedAt
}

model CartItem {
id        String  @id @default(uuid())
cartId    String
cart      Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
productId String
product   Product @relation(fields: [productId], references: [id])
quantity  Int

// This will store the actual customer selections from the Dynamic Form Builder
customizationDetails Json?

createdAt DateTime @default(now())
updatedAt DateTime @updatedAt

@@index([cartId])
}

enum OrderStatus {
PENDING
PROCESSING
COMPLETED
CANCELLED
}

// STREAMING_CHUNK: Defining Orders and Order Items...
model Order {
id                String      @id @default(uuid())
orderNumber       String      @unique // E.g., #45897
userId            String
user              User        @relation(fields: [userId], references: [id])
shippingAddressId String
shippingAddress   Address     @relation(fields: [shippingAddressId], references: [id])

subTotal          Decimal     @db.Decimal(10, 2)
shippingCost      Decimal     @db.Decimal(10, 2)
totalAmount       Decimal     @db.Decimal(10, 2)
status            OrderStatus @default(PENDING)

// Stripe Specific Fields
stripeSessionId       String? @unique // Checkout Session ID
stripePaymentIntentId String? @unique // Payment Intent ID for Webhooks

items    OrderItem[]
payments Payment[]

createdAt DateTime @default(now())
updatedAt DateTime @updatedAt

@@index([userId])
@@index([stripePaymentIntentId])
}

model OrderItem {
id        String  @id @default(uuid())
orderId   String
order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
productId String
product   Product @relation(fields: [productId], references: [id])

quantity  Int
unitPrice Decimal @db.Decimal(10, 2)

// Preserved snapshot of user's form builder inputs at the time of order
customizationDetails Json?

createdAt DateTime @default(now())

@@index([orderId])
}

// STREAMING_CHUNK: Payment and Refund schemas...
// ==========================================
// Payment & Stripe Integration
// ==========================================

enum PaymentStatus {
PENDING
AUTHORIZED
SUCCESS
FAILED
REFUNDED
}

enum PaymentMethodType {
STRIPE_CARD
STRIPE_APPLE_PAY
STRIPE_GOOGLE_PAY
}

model Payment {
id        String            @id @default(uuid())
orderId   String
order     Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)

amount    Decimal           @db.Decimal(10, 2)
currency  String            @default("USD")
status    PaymentStatus     @default(PENDING)
method    PaymentMethodType

// Stripe Data
stripeChargeId    String? @unique
rawStripeResponse Json?   // Storing raw webhook data

createdAt DateTime @default(now())
updatedAt DateTime @updatedAt

@@index([orderId])
}

model Refund {
id             String  @id @default(uuid())
paymentId      String
stripeRefundId String  @unique
amount         Decimal @db.Decimal(10, 2)
reason         String?
status         String  // e.g., succeeded, pending, failed

createdAt      DateTime @default(now())
}

// STREAMING_CHUNK: Review Schema...
// ==========================================
// Customer Reviews
// ==========================================

model Review {
id          String   @id @default(uuid())
productId   String
product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
userId      String
user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

rating      Int      // 1-5 scale
comment     String   @db.Text
isApproved  Boolean  @default(true)

createdAt   DateTime @default(now())
updatedAt   DateTime @updatedAt

@@index([productId])
@@index([userId])
}